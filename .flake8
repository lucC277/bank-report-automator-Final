[flake8]
max-line-length = 127
max-complexity = 12
ignore =
    E203,
    E501,
    W503,
    F821
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    venv/,
    env/,
    .venv/,
    build/,
    dist/,
    *.egg-info,
    .tox,
    .coverage,
    htmlcov/,
    .github/
per-file-ignores =
    __init__.py:F401